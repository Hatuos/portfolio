# =========================
# Security & supply chain
# =========================

# Prevents execution of lifecycle scripts (preinstall, postinstall, etc.)
ignore-scripts=true
# Blocks non-registry dependency sources (git, file://, URLs) to reduce supply chain risk
allow-git=none
# Rejects packages incompatible with the current Node.js/npm version
engine-strict=true

# =========================
# Auditing & transparency
# =========================

# Enables vulnerability auditing during npm operations
audit=true
# Disables funding messages for open-source dependencies
fund=false
