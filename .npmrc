# Prevents npm from running package lifecycle scripts during installation
ignore-scripts=true
# Enables vulnerability auditing during npm operation
audit=true
# Disables funding messages for open-source projects
fund=false
# Causes npm to reject packages that are incompatibles with the current Node.js or npm version
engine-strict=true
# Requieres a package version to be at least a certain age before npm will install it
minimum-release-age=43200
# Apply the minimum release age rule strictly and fail installation if a package is too new.
minimum-release-age-strict=true
# Block unusual/non-registry transitive dependencies (e.g., git, file, URL-based dependencies) to reduce supply-chain risk.
block-exotic-subdeps=true
# Fail installation when dependencies attempt to run build/install scripts unless they are explicitly allowed.
strict-dep-builds=true
# Reuse previously validated dependency state to make repeated installs faster while preserving checks.
optimistic-repeat-install=true
# Verify dependency integrity and policy compliance before executing an install operation.
verify-deps-before-run=install
# Prevents installing dependencies directly from Git repositories
allow-git=none